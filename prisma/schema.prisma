generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salary {
  id                 String   @id @default(cuid())
  company            String   // normalized, e.g., "google"
  originalCompany    String   // store raw for debugging
  role               String
  level              String   // L3, L4, L5, etc.
  location           String
  experienceYears    Int
  baseSalary         Int
  bonus              Int      @default(0)
  stock              Int      @default(0)
  totalCompensation  Int      // computed: base + bonus + stock
  confidenceScore    Float?   // optional
  createdAt          DateTime @default(now())
}
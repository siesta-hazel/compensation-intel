/node_modules/.prisma
/src/generated

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS metadata
.DS_Store
Thumbs.db

# IDE / Editor files
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath

# Temporary files
*.tmp
*.temp

# Testing coverage
/coverage

# Next.js debugging files
.next/trace
next-env.d.ts   # this is auto-generated, but it's fine to commit it (optional)

# Vercel (if using)
.vercel

